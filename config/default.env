# Void Linux install configuration — daily driver (UEFI + btrfs + glibc)
#
# This file is sourced by scripts/install.sh from the live ISO.
# Copy it and tweak per machine; pass the copy as the first argument:
#   ./scripts/install.sh config/my-laptop.env

# ── Target disk ──────────────────────────────────────────────────────
# The WHOLE disk is wiped. Use a stable path, e.g.:
#   /dev/disk/by-id/nvme-Samsung_SSD_980_1TB_S649NX0T123456
DISK=""

# ── Identity ─────────────────────────────────────────────────────────
HOSTNAME="framework-laptop"
USERNAME="davelens"
USER_GROUPS="wheel,audio,video,input,storage,network"

# Passwords: leave empty to be prompted interactively during install.
# Setting them here is intended for VM/test configs only.
ROOT_PASSWORD=""
USER_PASSWORD=""

# ── Locale / time ────────────────────────────────────────────────────
TIMEZONE="Europe/Brussels"
LOCALE="en_US.UTF-8"
KEYMAP="us"

# ── libc / repo ──────────────────────────────────────────────────────
# glibc chosen deliberately: Steam + Discord (proprietary, glibc-linked).
# For musl, set LIBC=musl; REPO_URL is derived automatically.
LIBC="glibc"
MIRROR="https://repo-default.voidlinux.org"

# ── Filesystem ───────────────────────────────────────────────────────
# GPT: p1 = ESP (FAT32), p2 = btrfs with subvolumes.
ESP_SIZE_MIB="512"
BTRFS_OPTS="compress=zstd,noatime"
# Subvolume layout: name=mountpoint (relative to /)
SUBVOLUMES="@=/ @home=/home @snapshots=/.snapshots"

# ── Packages ─────────────────────────────────────────────────────────
# Installed into the chroot during base install. Keep this minimal and
# bootable; everything else belongs in post.sh's package list.
PACKAGES="base-system btrfs-progs grub-x86_64-efi NetworkManager dbus polkit chrony tmux neovim git curl python mise"

# Extra packages installed by post.sh on the running system.
POST_PACKAGES="flatpak mise btop ripgrep"

# Nonfree/multilib repos + Steam (glibc only). Discord goes via Flatpak.
ENABLE_STEAM="yes"
ENABLE_DISCORD_FLATPAK="yes"

# ── Services (runit) ─────────────────────────────────────────────────
# Symlinked into /etc/runit/runsvdir/default/ inside the chroot.
SERVICES="dbus NetworkManager chronyd"
