# Void Linux install configuration — QEMU test VM
#
# Used by vm/run.sh + the unattended test flow. Everything is fixed and
# non-interactive so a VM install is fully reproducible.

DISK="/dev/vda"

HOSTNAME="void-vm"
USERNAME="davelens"
USER_GROUPS="wheel,audio,video,input,storage,network"

# Fixed passwords: fine for a throwaway VM, never for real hardware.
ROOT_PASSWORD="voidlinux"
USER_PASSWORD="voidlinux"

TIMEZONE="Europe/Brussels"
LOCALE="en_US.UTF-8"
KEYMAP="us"

LIBC="glibc"
MIRROR="https://repo-default.voidlinux.org"

ESP_SIZE_MIB="512"
BTRFS_OPTS="compress=zstd,noatime"
SUBVOLUMES="@=/ @home=/home @snapshots=/.snapshots"

# Keep the VM lean; no Steam in a test VM.
PACKAGES="base-system btrfs-progs grub-x86_64-efi NetworkManager dbus polkit chrony tmux neovim git curl python mise"
POST_PACKAGES="mise btop ripgrep"
ENABLE_STEAM="no"
ENABLE_DISCORD_FLATPAK="no"

SERVICES="dbus NetworkManager chronyd sshd"
